<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Всі статті</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>
  <h1>Блог</h1>
  <ul>
    <% articles.forEach(article=> { %>
      <li>
        <a href="/articles/<%= article.id %>">
          <%= article.title %>
        </a>
      </li>
      <% }); %>
  </ul>
  <hr>
  <a href="/users">Перейти до списку користувачів</a>
</body>

</html>