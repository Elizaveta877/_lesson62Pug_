doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Список користувачів
    link(rel="stylesheet", href="/styles.css")
  body
    h1 Наші користувачі
    ul
      each user in users
        li
          
          a(href=`/users/${user.id}`) #{user.name}
    
    hr
    a(href="/articles") Перейти до статей